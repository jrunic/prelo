{
  "name": "prelo",
  "version": "1.0.0",
  "description": "Converte Markdown em PDF com identidade visual de marca",
  "type": "commonjs",
  "main": "index.js",
  "bin": { "prelo": "./cli.js" },
  "scripts": {
    "fonts": "node scripts/download-fonts.js --url \"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap\" --dest brands/exemplo/fonts",
    "test": "node --test"
  },
  "keywords": ["markdown", "pdf", "puppeteer", "cli", "brand"],
  "author": "jrunic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jrunic/prelo.git"
  },
  "homepage": "https://github.com/jrunic/prelo#readme",
  "bugs": {
    "url": "https://github.com/jrunic/prelo/issues"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "puppeteer": "^22.0.0"
  }
}
